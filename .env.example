# Copy this file to .env and fill in the values you use.

# Chat provider for notebook generation cells. Use gemini by default, or openrouter for cheap OpenAI-compatible chat models.
RAG_CHAT_PROVIDER=gemini

# Required when RAG_CHAT_PROVIDER=gemini.
GOOGLE_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# Required when RAG_CHAT_PROVIDER=openrouter.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=rag-from-scratch

# Local uses an API-free TF-IDF embedding helper. Set to gemini for hosted Gemini embeddings.
RAG_EMBEDDING_PROVIDER=local

# Required only for the Cohere reranking sections in rag_from_scratch_15_to_18.ipynb.
COHERE_API_KEY=

# Optional LangSmith tracing.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
